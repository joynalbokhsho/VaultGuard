# ============================================================
#  VaultGuard — .gitignore
#  Next.js 15 · Prisma · TypeScript · Turbopack
# ============================================================

# ── Dependencies ─────────────────────────────────────────────
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js ──────────────────────────────────────────────────
.next/
out/
build/

# ── Prisma ───────────────────────────────────────────────────
# Generated client — always regenerated via `prisma generate`
src/generated/prisma/
# SQLite dev database (use .env.example for the URL instead)
*.db
*.db-journal
*.sqlite
*.sqlite-journal

# ── Environment & Secrets ────────────────────────────────────
# NEVER commit real secrets. Commit .env.example instead.
.env
.env.*
!.env.example

# ── TypeScript ───────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Testing & Coverage ───────────────────────────────────────
coverage/
.nyc_output/
playwright-report/
test-results/

# ── Debug & Logs ─────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ── OS & Editor artifacts ────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.pem

# Editor configs (uncomment if your team uses multiple editors)
# .vscode/
# .idea/
# *.suo
# *.ntvs*
# *.njsproj
# *.sln

# ── Deployment ───────────────────────────────────────────────
.vercel
.netlify

# ── Misc ─────────────────────────────────────────────────────
*.tgz
*.zip
package-lock.json
