# =============================
# VaultGuard — Environment Variables
# =============================

# --- Database (Supabase PostgreSQL) ---
# Get from: https://supabase.com/dashboard/project/_/settings/database
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# --- Better Auth ---
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET="your-super-secret-key-min-32-chars"
BETTER_AUTH_URL="http://localhost:3000"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="VaultGuard"

# --- Resend (Email) ---
# Get from: https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="noreply@yourdomain.com"

# --- Rate Limiting (Upstash Redis — optional but recommended) ---
# Get from: https://console.upstash.com/
# Leave empty to use in-memory rate limiting
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- Security ---
# Generate with: openssl rand -hex 32
CSRF_SECRET="your-csrf-secret-min-32-chars"

# --- HaveIBeenPwned (optional breach detection) ---
HIBP_API_KEY=""

# =============================
# PRODUCTION ADDITIONAL VARS
# =============================
# BETTER_AUTH_URL="https://yourdomain.com"
# NEXT_PUBLIC_APP_URL="https://yourdomain.com"
